general {
  output_format = "i3bar"
  colors = true
  interval = 5
  color_good = "#1b5e20"
  color_bad = "#b71c1c"
}


order += "wireless wls4"
order += "cpu_usage"
order += "load"
order += "tztime local"
/* order += "disk /" */

cpu_usage {
  format = "%usage"
}

load {
  format = "%1min"
}
wireless wls4 {
  format_up = "%essid%quality"
  format_down = "Not connected to WiFi"
}

tztime local {
  format = "%H:%M"
}


disk "/" {
  format = "%free"
}
