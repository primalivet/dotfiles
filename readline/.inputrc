# basic settings
# -----------------------------------------------------------------------------
# no bells
set bell-style none

# display possible completions in color uses LS_COLORS
set colored-stats on

# use color to show the common completion prefix, uses LS_COLORS
# set colored-completion-prefix on

# when completing, don't be case sensative and treat underscors as hyphens
set completion-ignore-case on
set completion-map-case on

# dont make me confirm completion when many items
set completion-query-items -1

# switch ~ for full path
set expand-tilde on

# try to keep cursor column when jumping in history
set history-preserve-point on

# add trailing slash for dirs and symlinked dirs
set mark-directories on
set mark-symlinked-directories on

# match hidden files
set match-hidden-files off

# show the common prefix before going through the completion list items
set menu-complete-display-prefix on

#
set print-completions-horizontally on

# show me multiple completions on first tab
set show-all-if-ambiguous on

# vi mode settings
# -----------------------------------------------------------------------------
# use vi mode everywhere with GNU readline
set editing-mode vi

# show "normal"/"insert" mode in prompt
set show-mode-in-prompt on

# set prompt text for command/insert mode uses \1 and \2 insead of \[ and \] 
# to start and end escape sequens
#
# set vi-cmd-mode-string "\1\e[32m\2COMMAND\1\e[0m\2 "
# set vi-ins-mode-string "\1\e[34m\2INSERT \1\e[0m\2 "
set vi-cmd-mode-string "(cmd) "
set vi-ins-mode-string "(ins) "

# mappings for command mode
set keymap vi-command

# mappings for insert mode
set keymap vi-insert

# tab cycles possible completions
TAB: menu-complete
