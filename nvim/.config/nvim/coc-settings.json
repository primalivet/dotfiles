{
	"eslint.filetypes": ["javascript", "typescript", "javscriptreact", "typescriptreact"],
	"eslint.autoFixOnSave": true,
	"stylelint.filetypes": [ "css", "scss", "less", "vue" ],
	"intelephense.diagnostics.enable": false,
	"diagnostic-languageserver.linters": {
		"phpcs": {
			"command": "./vendor/bin/phpcs",
			"debounce": 100,
			"rootPatterns": [ "composer.json", "composer.lock", "vendor", ".git", ".phpcs.xml" ],
			"args": [ "--report=emacs", "-s", "-" ],
			"offsetLine": 0,
			"offsetColumn": 0,
			"sourceName": "phpcs",
			"formatLines": 1,
			"formatPattern": [
				"^.*:(\\d+):(\\d+):\\s+(.*)\\s+-\\s+(.*)(\\r|\\n)*$",
				{
					"line": 1,
					"column": 2,
					"message": 4,
					"security": 3
				}
			],
			"securities": {
				"error": "error",
				"warning": "warning"
			}
		}
	},
	"diagnostic-languageserver.formatters": {
		//"phpcbf": {
		//	"command": "./vendor/bin/phpcbf",
		//	"rootPatterns": [ "composer.json", "composer.lock", "vendor", ".git" ],
		//	"args": ["--standard=.phpcs.xml", "%file"],
		//	"isStdout": false,
		//	"doesWriteToFile": true
		//}
	},
	"diagnostic-languageserver.filetypes": {
		"php": "phpcs"
	},
	"diagnostic-languageserver.formatFiletypes": {
		//"php": "phpcbf"
	}
}
