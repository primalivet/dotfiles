{

  // COC

  // "coc.preferences.formatOnSaveFiletypes": [
  //   "purescript"
  // ],
	"coc.preferences.formatOnSaveFiletypes": ["js", "css", "typescript"],

	// LSPs

  "languageserver": {
    "purescript": {
      "command": "purescript-language-server",
      "args": ["--stdio"],
      "filetypes": ["purescript"],
      "trace.server": "off",
      "rootPatterns": ["bower.json", "psc-package.json", "spago.dhall"],
      "settings": {
        "purescript": {
          "addSpagoSources": true
          //"addNpmPath": true // Set to true if using a local purty install for formatting etc
        }
      }
    }
  },

	// ESLint 

	"eslint.autoFixOnSave": true,

	// Typescript
	"typescript.suggest.autoImports": true,

	// Javascript

	"javascript.suggestionActions.enabled": false,

	// Diagnostic Languageserver

	"diagnostic-languageserver.linters": {
		"phpcs": {
			"command": "./vendor/bin/phpcs",
			"debounce": 3000,
			"rootPatterns": [
				"composer.json",
				"composer.lock",
				"vendor",
				".git"
			],
			"args": [
				"--report=emacs",
				"-s",
				"-"
			],
			"offsetLine": 0,
			"offsetColumn": 0,
			"sourceName": "phpcs",
			"formatLines": 1,
			"formatPattern": [
				"^.*:(\\d+):(\\d+):\\s+(.*)\\s+-\\s+(.*)(\\r|\\n)*$",
				{
					"line": 1,
					"column": 2,
					"message": 4,
					"security": 3
				}
			],
			"securities": {
				"error": "error",
				"warning": "warning"
			}
		}
	},
	"diagnostic-languageserver.filetypes": {
		"php": [
			"phpcs"
		]
	}
  //
  // PHPCS & PHPCBF linting and fixing through coc-diagnostic
  // ---
  // PHPCS works great as a linter, however the companion fixer tool phpcbf
  // dont work at all thorugh coc-diagnostic it seems. At the best phpcbf
  // would fix the current buffer but with the wrong phpcs.xml config.
  //
  // There is a Github issue on this problem at:
  // https://github.com/iamcco/coc-diagnostic/issues/38
  //
  // As a result of that the phpcbf is ran thorugh the binding for fixing
  // current file in vimrc/init.vim.
